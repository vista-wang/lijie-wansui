# 理解万岁 · 环境变量示例
# 复制为 .env.local 后填写（勿提交含密钥的本地文件）

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# 站点对外 URL（微信回调 / OIDC issuer 依赖）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase 内容库
NEXT_PUBLIC_SUPABASE_URL=https://qophqzbssamxrrjnsggu.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# SUPABASE_SERVICE_ROLE_KEY=

# —— 微信网站登录 → Clerk Custom Provider（OIDC 代理）——
# 开放平台「网站应用」AppID / AppSecret（扫码登录 qrconnect，不是 PC OpenSDK）
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# 你在 Clerk Custom provider 里填写的 Client ID / Secret（自拟，与代理校验用）
WECHAT_OIDC_CLIENT_ID=lijie-wechat
WECHAT_OIDC_CLIENT_SECRET=change-me
# 可选：签发 pending/code/id_token 的密钥
# WECHAT_OIDC_JWT_SECRET=

# —— Lemon Squeezy 广告 API ——
LEMONSQUEEZY_API_KEY=
# 可选：限定店铺
# LEMONSQUEEZY_STORE_ID=
